# ─── Required ────────────────────────────────────────────────────────────────

# Payer wallet private key (0x-prefixed 32-byte hex)
4MICA_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── Connection (optional — have defaults) ───────────────────────────────────

# 4Mica core RPC URL (default: http://localhost:3000/)
#4MICA_RPC_URL=http://localhost:3000/

# Recipient private key — omit to reuse payer key (useful for local demos)
RECIPIENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── Step 2: Deposit ─────────────────────────────────────────────────────────

# Amount of USDC to deposit as collateral (default: 1.0)
#DEPOSIT_AMOUNT=1.0

# ─── Step 3: Open Tab ────────────────────────────────────────────────────────

# Tab time-to-live in seconds; 0 = no expiry (default: 300)
#TAB_TTL_SECONDS=300

# ─── Step 4: V1 Guarantee ────────────────────────────────────────────────────

# Amount to guarantee in USDC (default: 0.001)
#GUARANTEE_AMOUNT=0.001

# ─── Step 5: V2 Guarantee (on-chain validation policy) ───────────────────────

# Amount to guarantee in USDC (default: 0.001)
#V2_GUARANTEE_AMOUNT=0.001

# Validation registry contract address
# If left unset, the first trusted registry returned by the core is used automatically
#VALIDATION_REGISTRY=0x

# Chain ID of the validation registry (default: same chain as 4Mica core)
#VALIDATION_CHAIN_ID=

# Validator contract address (required for V2)
#VALIDATOR_ADDRESS=0x

# Validator agent ID (default: 1)
#VALIDATOR_AGENT_ID=1

# Minimum validation score accepted (1–100, default: 80)
#MIN_VALIDATION_SCORE=80

# Required validation tag string — empty string means no tag required
#VALIDATION_TAG=

# ─── Step 8: Withdrawal ──────────────────────────────────────────────────────

# Amount to request for withdrawal in USDC (default: 0.001)
#WITHDRAW_AMOUNT=0.001
